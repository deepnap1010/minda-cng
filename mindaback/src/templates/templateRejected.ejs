<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Template Rejected</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; color: #1f2937; }
      .container { max-width: 560px; margin: 0 auto; padding: 24px; }
      .badge { display: inline-block; padding: 4px 10px; border-radius: 9999px; background: #fee2e2; color: #991b1b; font-weight: 600; font-size: 12px; }
      .card { border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; }
      .footer { color: #6b7280; font-size: 12px; margin-top: 24px; }
    </style>
  </head>
  <body>
    <div class="container">
      <h2>Hi <%= recipientName %>,</h2>
      <div class="card">
        <p>We reviewed your template:</p>
        <p>
          <span class="badge">Rejected</span>
          <strong style="margin-left:8px;"><%= templateName %></strong>
        </p>
        <p style="margin-top: 12px;">
          This template was rejected during the approval workflow. Please review feedback in the application and make necessary changes before resubmitting.
        </p>
      </div>
      <p class="footer">
        This is an automated message. Please do not reply.
      </p>
    </div>
  </body>
  </html>


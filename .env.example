# ──────────────────────────────────────────────────────────────────────────
# JFE TraceLine — environment
# Copy to .env at the repo root:  cp .env.example .env
# The server loads this root .env regardless of which workspace it runs from.
# Nothing here is hardcoded in code — every value below is read at runtime.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development
LOG_LEVEL=info

# ── API server ──────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed CORS origins (the Vite client dev server).
CORS_ORIGINS=http://localhost:5173

# ── Microsoft SQL Server (Sequelize, tedious dialect) ────────────────────────
# Connection string format (informational):
#   Server=tcp:{DB_HOST},{DB_PORT};Database={DB_NAME};User Id={DB_USER};Password={DB_PASSWORD};
# With docker-compose (see docker-compose.yml) the defaults below "just work".
# The database is auto-created on first boot if it does not exist.
DB_HOST=localhost
DB_PORT=1433
DB_NAME=jfe_traceline
DB_USER=sa
DB_PASSWORD=Jfe_TraceLine#2026
# encrypt=true for Azure SQL / TLS endpoints; false for a plain local dev container
DB_ENCRYPT=false
# trust a self-signed cert (true for local dev / dockerized MSSQL)
DB_TRUST_SERVER_CERT=true
DB_POOL_MAX=10

# ── Redis (ioredis) — latest live values + cache ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Auth (JWT stub for now; swap to JPM SSO later) ───────────────────────────
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=12h

# ── Client (Vite) ────────────────────────────────────────────────────────────
# In dev the Vite server proxies /api and /socket.io to the API (see vite.config.ts),
# so these are usually left blank. Set them only for a non-proxied / production build.
# VITE_API_URL=
# VITE_SOCKET_URL=

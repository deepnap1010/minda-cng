# Local dev overrides — loaded ONLY by `npm run dev` (Vite development mode).
# A production `npm run build` uses .env instead, so these never ship to prod.

# Point the app at your LOCAL backend (Vite proxies /api/v1 here).
VITE_BACKEND_URL=http://localhost:9021/api/v1

# Real login is used now (a demo user is seeded). Set to true only if you'd
# rather skip login entirely (then also run the backend with CNG_PUBLIC_READS=true).
VITE_AUTH_BYPASS=false
